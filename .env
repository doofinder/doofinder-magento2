# MySQL configuration
MYSQL_DATABASE=magentobase
MYSQL_USER=magentobase
MYSQL_PASSWORD=magentobase

# PHP_VERSION, COMPOSER_VERSION, and MAGENTO_VERSION must be kept in sync.
# The Makefile auto-selects OpenSearch (>= 2.4.8) or Elasticsearch (< 2.4.8) based on MAGENTO_VERSION.
# See the compatibility matrix in README.md for valid combinations.
PHP_VERSION=8.3
COMPOSER_VERSION=2.7.7
MAGENTO_EDITION=community
MAGENTO_VERSION=2.4.7-p3

# Magento setup configuration data
# BASE_URL is the shop hostname as seen by Docker — do NOT include https:// or a trailing slash.
# Must be publicly reachable for the Doofinder login/signup flow to work.
# Override in .env.local for local dev (e.g. your tunnel hostname).
BASE_URL=localhost:9012
MAGENTO_ADMIN_FRONTNAME=admin
MAGENTO_ADMIN_FIRST_NAME=Administrator
MAGENTO_ADMIN_LAST_NAME=Test
MAGENTO_ADMIN_EMAIL=example@email.com
# Admin panel credentials — change these for anything beyond local-only use.
MAGENTO_ADMIN_USER=admin
MAGENTO_ADMIN_PASSWORD=admin123
MAGENTO_LOCALE=en_US
MAGENTO_CURRENCY=EUR
MAGENTO_TIMEZONE=Europe/Madrid

# XDebug configuration data
# XDEBUG_HOST is the Docker bridge IP — 172.17.0.1 on Linux. On macOS use host.docker.internal.
XDEBUG_HOST=172.17.0.1
XDEBUG_KEY=phpstorm-xdebug

# Tokens for the Magento composer repository.
# Obtain from https://marketplace.magento.com/customer/accessKeys/ (public key / private key).
# Set these in .env.local to avoid committing credentials.
COMPOSER_AUTH_USERNAME=
COMPOSER_AUTH_PASSWORD=

# Doofinder service URLs injected into the module via `make doofinder-configure`.
# These point to production by default. Override in .env.local for local development.
DOOFINDER_ADMIN_URL=https://admin.doofinder.com
DOOFINDER_PLUGINS_URL_FORMAT=https://%s-plugins.doofinder.com
DOOFINDER_SEARCH_URL_FORMAT=https://%s-search.doofinder.com
DOOFINDER_API_URL_FORMAT=https://%s-api.doofinder.com
DOOFINDER_SCRIPT_URL_FORMAT=https://%s-config.doofinder.com/2.x/%s.js
